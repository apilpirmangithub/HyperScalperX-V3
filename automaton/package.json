{
  "name": "hyper-scalper-clean",
  "version": "1.0.0",
  "description": "HyperScalperX Specialized Trading Bot (Clean Build)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "automaton": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs'); fs.mkdirSync('dist/dashboard', {recursive:true}); fs.copyFileSync('src/dashboard/index.html', 'dist/dashboard/index.html')\"",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nktkas/hyperliquid": "^0.31.0",
    "axios": "^1.13.5",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.16.0",
    "node-ssh": "^13.2.1",
    "viem": "^2.44.2",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
